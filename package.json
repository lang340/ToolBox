{
  "name": "toolbox",
  "version": "0.1.0",
  "description": "绿色便携桌面工具箱 - 番茄钟/剪贴板/日程任务/日记本",
  "main": "src/main/index.js",
  "scripts": {
    "start": "cross-env ELECTRON_RUN_AS_NODE= electron .",
    "build": "electron-builder --win portable",
    "test": "echo \"E2E tests in P3\" && exit 0"
  },
  "author": "海金",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "sql.js": "^1.11.0"
  },
  "build": {
    "appId": "com.toolbox.app",
    "productName": "ToolBox",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "artifactName": "ToolBox-v${version}-Portable.exe"
    },
    "portable": {
      "artifactName": "ToolBox-v${version}-Portable.exe"
    },
    "files": [
      "src/**/*",
      "preload.js",
      "data/**/*"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
